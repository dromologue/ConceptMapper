/target
/web/node_modules
/web/dist
# web/src/wasm (wasm-pack output) is committed so the `web` CI job and a clean
# clone can `npm run build` without first running wasm-pack. Regenerated by
# scripts/build-app.sh; commit it after any Rust parser change. wasm-pack drops
# its own `*` .gitignore in that dir on every build — ignore just that nested
# file so it never re-hides the tracked artifacts or dirties `git status`.
/web/src/wasm/.gitignore
# macos/ConceptMapper.xcodeproj and macos/Resources/web are committed so
# Xcode Cloud can build from a clean clone (generated by scripts/build-app.sh).
/macos/build
# Swift Package / SwiftPM build caches (never commit — they bloat history)
.build/
# Per-user Xcode state inside the committed project
**/xcuserdata/
*.xcuserstate
.env
.env.local
.DS_Store
.claude/settings.local.json
/support-site
/ios/build
