/target
/web/node_modules
/web/dist
# web/src/wasm (wasm-pack output) is committed so the `web` CI job and a clean
# clone can `npm run build` without first running wasm-pack. Regenerated by
# scripts/build-app.sh; commit it after any Rust parser change. wasm-pack drops
# its own `*` .gitignore in that dir on every build — ignore just that nested
# file so it never re-hides the tracked artifacts or dirties `git status`.
/web/src/wasm/.gitignore
# macos/ConceptMapper.xcodeproj and macos/Resources/web are committed so
# Xcode Cloud can build from a clean clone (generated by scripts/build-app.sh).
/macos/build
# Swift Package / SwiftPM build caches (never commit — they bloat history)
.build/
# Per-user Xcode state inside the committed project
**/xcuserdata/
*.xcuserstate
.env
.env.local
.env.test
*.credentials
test-credentials*
.workflowy-key
.DS_Store
.claude/settings.local.json
/support-site
/ios/build

# Local Netlify folder
.netlify

# Deployment infrastructure for hosting the release DMG on fly.io.
# The public repo only needs what's required to build and run the app, not the
# maintainer's binary-hosting setup. These stay local to the release machine.
/fly/
/scripts/deploy-downloads.sh

# Internal planning, task, spec, and release-process docs — kept local, never
# shipped to the public repo. Only the code needed to build and run the app ships.
/TODO.md
/tasks/
/APP_STORE_LAUNCH.md
/SPEC.md
/TRACEABILITY.md
/RELEASING.md
/specs/
